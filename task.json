{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                // --- AQUÍ EMPIEZA LO NUEVO PARA RAYLIB ---
                "-I", "C:\\raylib\\raylib-5.5_win64_mingw-w64\\include",
                "-L", "C:\\raylib\\raylib-5.5_win64_mingw-w64\\lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
                // --- AQUÍ TERMINA LO NUEVO ---
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Tarea configurada para Raylib 5.5"
        }
    ],
    "version": "2.0.0"
}
